# OmniQuantAI testnet/devnet deployment template.
# Copy to .env on the deployment host and fill only the secret values.
# Never commit .env or real key material.

SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
ALLOW_MAINNET=

# Generated by npm run bootstrap or node scripts/setup.js.
# The buyer wallet signs devnet escrow deposits/releases and must be funded with devnet SOL.
BUYER_KEYPAIR_B58=

# Seller receives the released payment. WALLET should be the seller public key.
SELLER_KEYPAIR_B58=
WALLET=

# Required for arbiter-gated mode. Direct devnet escrow can still be used for controlled proof runs.
ARBITER_KEYPAIR_B58=

# Persistence: keep enabled for deployment proof/history.
OMNIQUANT_PERSIST=1
OMNIQUANT_DATA_DIR=.omniquant-data

# Optional LLM/data providers. Missing keys must not break the deployment.
LLM_PROVIDER=
LLM_MODEL=
VENICE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
FINNHUB_API_KEY=
NEWS_API_KEY=
FMP_API_KEY=
PYTH_SOL_USD_FEED_ID=

# Public API/frontend configuration.
# Leave blank for local/Codespaces same-origin proxy; set explicitly for split deployments.
VITE_API_BASE_URL=
VITE_FEED_URL=

# Mainnet remains blocked for this release lane.
MAINNET_ESCROW_PROGRAM_ID=
MAINNET_ARBITER_PROGRAM_ID=
MAX_MAINNET_ORDER_SOL=
MAINNET_RISK_ACK=
