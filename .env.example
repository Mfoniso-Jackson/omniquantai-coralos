# Copy to .env and fill in. Never commit .env — it is gitignored.

# ── Wallets (node scripts/setup.js generates these) ───────────────────────────

# Buyer keypair (base58 secret) — signs the escrow deposit/release and the TxLINE subscribe.
# Fund it at https://faucet.solana.com (GitHub sign-in; CLI/RPC airdrops are gated).
BUYER_KEYPAIR_B58=

# Seller keypair (base58 secret) — a distinct party so settlement is a real two-party transfer.
# It only RECEIVES on release, so it needs no funding. (setup.js generates this.)
SELLER_KEYPAIR_B58=

# Seller public key — the escrow's payout destination. setup.js sets this to SELLER_KEYPAIR_B58's
# pubkey. If unset, settle() self-pays the buyer (one-wallet demo; not a real two-party transfer).
WALLET=

# Arbiter keypair (base58 secret) — the neutral 3rd signer that gates release/refund (the trustless
# wrapper, examples/txodds/escrow/programs/arbiter). When set, settle() routes through the arbiter so
# the buyer can't take delivery and refund. Needs only tx-fee funds — the proxy tops it up from the
# buyer automatically. If unset, settle() falls back to the direct buyer-released escrow. (setup.js generates this.)
ARBITER_KEYPAIR_B58=

SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# ── Mainnet preparation (not used by the default testnet/devnet lane) ─────────
# Do not set these for the current testnet/devnet release. The app remains devnet-first until escrow
# and arbiter programs are separately deployed/audited on mainnet and transaction caps are reviewed.
# Run `npm run mainnet-readiness` before any controlled mainnet dry run.
ALLOW_MAINNET=
MAINNET_ESCROW_PROGRAM_ID=
MAINNET_ARBITER_PROGRAM_ID=
MAX_MAINNET_ORDER_SOL=
MAINNET_RISK_ACK=

# ── LLM brain (the agent's reasoning + delivery) ──────────────────────────────

# This kit's LLM is Venice AI — OpenAI-compatible, with free credits. Create a key at
# https://venice.ai/settings/api; new accounts get $50 free with redeem code IMPERIAL50 (bottom of that
# page). Recommended: set both of these.
#   LLM_PROVIDER=venice
VENICE_API_KEY=

# Alternatives (no code change) — set LLM_PROVIDER + the matching key:
#   LLM_PROVIDER=openai      → OPENAI_API_KEY=...
#   LLM_PROVIDER=anthropic   → ANTHROPIC_API_KEY=...
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

LLM_PROVIDER=
LLM_MODEL=

# ── Optional OmniQuantAI live data providers ─────────────────────────────────
# The demo never requires these. When unset or when calls fail, sellers use deterministic fallback data.
FINNHUB_API_KEY=
NEWS_API_KEY=
FMP_API_KEY=
PYTH_SOL_USD_FEED_ID=

# ── Platform deployment configuration ────────────────────────────────────────
# Keep the frontend stateless. Only VITE_* values are safe to expose to browser builds.
OMNIQUANT_ENV=local
PUBLIC_WEB_URL=http://localhost:5173
PUBLIC_APP_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:4000
VITE_API_BASE_URL=

# API service
API_HOST=0.0.0.0
PORT=4000
API_VERSION=v1
CORS_ORIGINS=http://localhost:5173,https://omniquantai.com,https://app.omniquantai.com
JWT_ISSUER=omniquantai
JWT_AUDIENCE=omniquantai-api
JWT_SECRET=
REGISTRY_AUTH_SECRET=
REQUEST_TIMEOUT_MS=30000

# Persistence. Local development defaults to file-backed `.omniquant-data`.
OMNIQUANT_PERSIST=1
OMNIQUANT_DATA_DIR=.omniquant-data
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Queue and worker runtime
REDIS_URL=
QUEUE_PREFIX=omniquant
WORKER_CONCURRENCY=2
JOB_ATTEMPTS=3
JOB_BACKOFF_MS=5000
DEAD_LETTER_QUEUE=omniquant:dead-letter

# CoralOS bridge/runtime
CORAL_SERVER_URL=http://localhost:5555
CORAL_TOKEN=dev
CORAL_NAMESPACE=omniquant
CORAL_BRIDGE_URL=http://localhost:4100
CORAL_DOCKER_NETWORK=omniquant

# Object storage for large memo/proof artifacts
OBJECT_STORAGE_PROVIDER=
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Observability
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
METRICS_ENABLED=0

# ── TxLINE (optional) ─────────────────────────────────────────────────────────
# The proxy subscribes the buyer wallet to the free World Cup tier on its own, so you don't need to
# set these. `npm run mint` (examples/txodds) writes TXLINE_API_KEY here for the standalone TxLineClient.
TXLINE_API_KEY=
TXLINE_BASE_URL=

# Override the TxLINE devnet ids if TxODDS rotates them (defaults are baked into the proxy):
TXLINE_PROGRAM=          # subscription program id (default 6pW64…P2J)
TXLINE_MINT=             # treasury token mint    (default 4Zao8o…EokRG)
